{
  "manifest_version": 3,
  "name": "AI GitHub Grader Helper",
  "version": "3.3.0",
  "description": "Chấm điểm trực tiếp repository GitHub của học viên thông qua mô hình Trí Tuệ Nhân Tạo.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}

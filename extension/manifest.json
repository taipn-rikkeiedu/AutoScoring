{
  "manifest_version": 3,
  "name": "REduX",
  "version": "3.6.0",
  "description": "Chấm điểm trực tiếp repository GitHub của học viên thông qua mô hình Trí Tuệ Nhân Tạo.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["https://qldt.rikkei.edu.vn/*"],
      "js": ["content.js"],
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
